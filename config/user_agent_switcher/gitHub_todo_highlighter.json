// ==UserScript==
// @name         GitHub TODO Highlighter (safe polling)
// @namespace    local
// @version      1.0
// @match        https://github.com/*
// @match        https://gist.github.com/*
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function () {
  'use strict';

  const ROOT_SELECTOR = '.markdown-body';
  const PROCESSED_ATTR = 'data-todo-scan-complete';
  const HIGHLIGHT_ATTR = 'data-todo-highlighted';

  function shouldSkipTextNode(node) {
    if (!node || !node.parentElement) return true;
    if (node.parentElement.closest('pre, code, textarea, script, style, mark[' + HIGHLIGHT_ATTR + ']')) return true;
    return !node.nodeValue || !node.nodeValue.includes('TODO');
  }

  function processRoot(root) {
    if (!root || root.hasAttribute(PROCESSED_ATTR)) return;

    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
    const nodes = [];
    let n;

    while ((n = walker.nextNode())) {
      if (!shouldSkipTextNode(n)) nodes.push(n);
    }

    for (const textNode of nodes) {
      const frag = document.createDocumentFragment();
      const parts = textNode.nodeValue.split(/(TODO)/g);

      if (parts.length <= 1) continue;

      for (const part of parts) {
        if (part === 'TODO') {
          const mark = document.createElement('mark');
          mark.textContent = part;
          mark.setAttribute(HIGHLIGHT_ATTR, '1');
mark.style.backgroundColor = '#ff4d4f';
mark.style.color = '#fff';
mark.style.fontWeight = '700';
mark.style.padding = '1px 6px';
mark.style.borderRadius = '999px';
mark.style.boxShadow = '0 0 0 2px rgba(255,77,79,0.25)';
mark.style.margin = '0 2px';
          frag.appendChild(mark);
        } else if (part) {
          frag.appendChild(document.createTextNode(part));
        }
      }

      textNode.parentNode.replaceChild(frag, textNode);
    }

    root.setAttribute(PROCESSED_ATTR, '1');
  }

  function tick() {
    document.querySelectorAll(ROOT_SELECTOR).forEach(processRoot);
  }

  tick();
  setInterval(tick, 1500);
})();
